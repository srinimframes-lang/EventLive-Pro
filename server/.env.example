# ──────────────────────────────────────────────
# EventLive Pro — Backend environment variables
# Copy this file to `.env` and fill in real values.
# ──────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Frontend origin(s) allowed by CORS. Comma-separate multiple origins (e.g. the
# custom domain + www). Do NOT include a trailing slash. The production domain
# https://eventlivepro.com (and www) is always allowed in addition to this.
# Prod example: CLIENT_URL=https://eventlivepro.com,https://www.eventlivepro.com
CLIENT_URL=http://localhost:5173

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/eventlive
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/eventlive?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/eventlive

# JWT
# Generate a strong secret, e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# ──────────────────────────────────────────────
# Super Admin (MaaEvents9) — auto-created on first boot.
# Change the password after your first login. If unset, a default account is
# created: admin@maaevents9.com / MaaEvents9@Admin (set these to override).
SUPER_ADMIN_NAME=MaaEvents9 Admin
SUPER_ADMIN_EMAIL=admin@maaevents9.com
SUPER_ADMIN_PASSWORD=change_me_strong_password

# Live streaming — MediaMTX VPS (Premium Server Live)
#
# DNS: stream.eventlivepro.com → 200.97.166.42 (see media-server/nginx/)
#
# RTMP ingest (OBS): public stream hostname.
RTMP_INGEST_URL=rtmp://stream.eventlivepro.com:1935/live
#
# Browser HLS playback — MUST be HTTPS (mixed-content safe on eventlivepro.com).
# Production default when unset: https://stream.eventlivepro.com
HLS_PLAYBACK_BASE=https://stream.eventlivepro.com
STREAM_PUBLIC_DOMAIN=stream.eventlivepro.com
#
# Optional WebRTC/WHEP via the same HTTPS domain.
WEBRTC_PLAYBACK_BASE=https://stream.eventlivepro.com
#
# Server-side MediaMTX API probe (internal HTTP is fine).
MEDIAMTX_API_URL=http://127.0.0.1:9997
#
# Force HTTPS playback URLs in local testing (optional).
# REQUIRE_SECURE_PLAYBACK=true
#
# Shared secret — must match MediaMTX auth webhook ?token= and x-media-secret header
MEDIA_SERVER_SECRET=

# White-label custom domains (Phase 3) — OPTIONAL Vercel integration.
# When set, approving a domain attaches it to the Vercel project (auto SSL) and
# reads its verification/SSL status. Leave blank to verify DNS only and attach
# the domain manually in the Vercel dashboard.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ──────────────────────────────────────────────
# Durable image storage (RECOMMENDED for production)
# Render's filesystem is ephemeral — uploaded gallery photos, logos and couple
# photos are LOST on every redeploy/restart unless stored externally.
# Set Cloudinary credentials to persist uploads. Without these, uploads fall
# back to local disk (fine for local dev, not durable on Render).
# Easiest: paste the single CLOUDINARY_URL from your Cloudinary dashboard.
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# …or set the three discrete variables instead:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────
# Credits are purchased via a manual UPI QR flow: customers pay to your UPI/QR
# (configured in Admin > Settings) and submit a request that you approve in the
# Admin Panel. No payment-gateway API keys are required.
