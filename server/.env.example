# ──────────────────────────────────────────────
# EventLive Pro — Backend environment variables
# Copy this file to `.env` and fill in real values.
# ──────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Frontend origin allowed by CORS (Vite dev server)
CLIENT_URL=http://localhost:5173

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/eventlive
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/eventlive?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/eventlive

# JWT
# Generate a strong secret, e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7
