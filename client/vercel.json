{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.eventlivepro.com" }],
      "destination": "https://eventlivepro.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://eventlive-pro.onrender.com/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://eventlive-pro.onrender.com/robots.txt"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
