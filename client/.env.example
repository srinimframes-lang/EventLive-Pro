# ──────────────────────────────────────────────
# EventLive Pro — Frontend environment variables
# Copy this file to `.env` and adjust as needed.
# Only variables prefixed with VITE_ are exposed to the client bundle.
# ──────────────────────────────────────────────

# Base URL for the backend API.
# In dev, the Vite proxy forwards /api -> http://localhost:5000,
# so the default below works out of the box.
VITE_API_URL=/api
