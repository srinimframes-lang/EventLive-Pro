# ──────────────────────────────────────────────
# EventLive Pro — Frontend environment variables
# Copy this file to `.env` and adjust as needed.
# Only variables prefixed with VITE_ are exposed to the client bundle.
# ──────────────────────────────────────────────

# Backend ORIGIN (scheme + host), WITHOUT a trailing /api — every request
# path already includes the /api prefix.
#
#   Local dev   : leave empty. The Vite proxy forwards /api -> localhost:5000.
#   Production  : set to your backend origin, e.g.
#                 VITE_API_URL=https://eventlive-pro.onrender.com
#
# A trailing slash or trailing "/api" is tolerated and stripped automatically.
VITE_API_URL=

# Optional: explicit Socket.IO server URL (defaults to same origin).
# In production set this to your backend origin (same as VITE_API_URL).
# VITE_SOCKET_URL=https://eventlive-pro.onrender.com

# Premium Server Live HLS base (HTTPS domain only — never use VPS IP or :8888).
# VITE_HLS_PLAYBACK_BASE=https://stream.eventlivepro.com
